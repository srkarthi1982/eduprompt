---
import AppShell from "../layouts/AppShell.astro";
import { AvButton, AvCard, AvContainer } from "@ansiversa/components";
import AvMiniAppBar from "../components/AvMiniAppBar.astro";
---

<AppShell title="EduPrompt | Ansiversa" description="Premium educator prompt library for everyday teaching.">
  <AvMiniAppBar />

  <section class="py-20">
    <AvContainer size="wide" className="px-4 grid lg:grid-cols-2 gap-10 items-center">
      <div class="space-y-5">
        <p class="text-sm uppercase tracking-widest text-cyan-300">Ansiversa · Educator productivity</p>
        <h1 class="text-4xl md:text-5xl font-semibold text-white leading-tight">Build a calm, organized prompt library for your classroom.</h1>
        <p class="text-slate-300 text-lg">EduPrompt V1 keeps your teaching prompts structured by subject, level, and category—without clutter or complexity.</p>
        <div class="flex gap-3">
          <AvButton href="/app">Open Workspace</AvButton>
        </div>
      </div>

      <AvCard variant="soft" className="p-6 space-y-4">
        <h2 class="text-xl text-white font-semibold">What you can do in V1</h2>
        <ul class="space-y-2 text-slate-300 list-disc list-inside">
          <li>Create and edit educational prompts.</li>
          <li>Organize by subject, level, and category.</li>
          <li>Star favorites and archive old prompts.</li>
          <li>Quickly search and filter your library.</li>
        </ul>
      </AvCard>
    </AvContainer>
  </section>
</AppShell>
